{
  "name": "paperwork",
  "version": "0.0.1",
  "description": "A bookkeeping app for small business owners in the Netherlands",
  "main": "server.ts",
  "scripts": {
    "start": "tsx server.ts",
    "server": "nodemon --exec tsx --ext js,ts,json server.ts",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "client": "npm run start --prefix client ",
    "prod": "npm run build --prefix client && npm start",
    "dev": "concurrently \"npm run server\" \"npm run start --prefix client\"",
    "build": "npm install && npm install --prefix client ",
    "heroku-postbuild": "NPM_CONFIG_PRODUCTION=false npm install --prefix client && npm run build --prefix client",
    "try": "npm run build --prefix client",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:unit": "jest --testPathPattern=unit",
    "test:integration": "jest --testPathPattern=integration",
    "eval:invoice-extraction": "tsx scripts/evals/invoiceExtraction/run.ts",
    "prepare": "husky || true"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix --no-warn-ignored",
      "prettier --write"
    ],
    "*.{js,jsx,json,md,css,yml,yaml}": "prettier --write"
  },
  "keywords": [],
  "author": "Henry Cordes, Dev Artist",
  "license": "ISC",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.106.0",
    "@aws-sdk/client-s3": "^3.445.0",
    "@aws-sdk/s3-request-presigner": "^3.445.0",
    "@mollie/api-client": "^4.3.2",
    "archiver": "^7.0.1",
    "bcrypt": "^6.0.0",
    "bull": "^4.16.5",
    "cls-hooked": "^4.2.2",
    "colors": "^1.4.0",
    "commander": "^14.0.0",
    "cors": "^2.8.5",
    "dotenv": "^8.2.0",
    "express": "^4.17.1",
    "express-mongo-sanitize": "^2.0.0",
    "express-validator": "^6.4.0",
    "firebase-admin": "^12.7.0",
    "helmet": "^3.22.0",
    "hpp": "^0.2.3",
    "html-pdf": "^3.0.1",
    "json2csv": "^6.0.0-alpha.2",
    "jsonwebtoken": "^9.0.2",
    "moment": "^2.29.1",
    "mongoose": "^8.15.1",
    "mongoose-sequence": "^6.0.1",
    "multer": "^1.4.5-lts.1",
    "multer-s3": "^3.0.0",
    "node-mailjet": "^6.0.8",
    "node-schedule": "^2.1.1",
    "patch-package": "^8.0.0",
    "pino": "^9.7.0",
    "pino-pretty": "^13.0.0",
    "robots.txt": "^1.1.0",
    "string-strip-html": "^13.4.12",
    "tsx": "^4.22.4",
    "uuid": "^8.3.2",
    "xlsx": "^0.18.5",
    "xss-clean": "^0.1.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@faker-js/faker": "^9.9.0",
    "@types/bcrypt": "^6.0.0",
    "@types/html-pdf": "^3.0.3",
    "@types/jest": "^29.5.14",
    "@types/json2csv": "^5.0.7",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.1.0",
    "@types/multer-s3": "^3.0.3",
    "@types/node": "^20.19.42",
    "@types/node-schedule": "^2.1.8",
    "@types/supertest": "^7.2.0",
    "@types/uuid": "^10.0.0",
    "concurrently": "^5.1.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "fast-check": "^4.6.0",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "lint-staged": "^17.0.7",
    "mongodb-memory-server": "^10.1.4",
    "nodemon": "^3.1.10",
    "prettier": "3.9.1",
    "supertest": "^7.1.1",
    "ts-jest": "^29.4.11",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.60.1"
  },
  "engines": {
    "node": ">=20.x",
    "npm": "10.9.2"
  }
}
