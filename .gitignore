# ignore everything in tmp/uploads folder, except for do-not-delete.txt
tmp/uploads/*
!tmp/uploads/do-not-delete.txt

# ignore everything in tmp/temp folder, except for do-not-delete.txt
tmp/temp/*
!tmp/temp/do-not-delete.txt

# ignore everything in tmp/pdf folder, except for factuur_1000.pdf
tmp/pdf/*
!tmp/pdf/factuur_1000.pdf


node_modules
npm-debug.log

dump/

